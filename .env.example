APP_MODE=server
HTTP_ADDR=:8080
ENABLE_SWAGGER=true
POSTGRES_DSN=postgres://video:video@127.0.0.1:5432/video_server?sslmode=disable
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
JWT_SECRET=change_me_to_a_long_random_secret
PLAY_URL_SIGN_SECRET=
ASYNQ_QUEUE=transcode
MAX_TRANSCODE_WORKERS=2
ACCESS_TOKEN_TTL_HOURS=87600
REFRESH_TOKEN_TTL_HOURS=168
# 管理端系统日志读取路径；留空 = 使用默认 ./.run/server.log（dev 模式）
# 家用部署机请填 launchd StandardOutPath 对应的绝对路径，例如 /Users/<user>/Library/Logs/ai-video-server/server.log
SERVER_LOG_PATH=
STORAGE_ROOT=./storage
POSTER_STORAGE_PATH=./storage/posters
# admin-web 已构建产物所在目录；留空 = 使用默认 admin-web/dist（dev 模式）；
# 家用部署机请填绝对路径，例如 /Users/<user>/deploy/ai-video-server/current/admin-web-dist
ADMIN_WEB_DIST_PATH=
# launchd 稳定签名身份；必须是 Apple-issued 的 Developer ID Application / Apple Development 证书
CODESIGN_IDENTITY=
# launchd 签名固定 identifier；不要让它随 video-server-<sha>.bin 文件名变化
CODESIGN_IDENTIFIER=com.chee.videos.server
# 可选：若签名身份放在独立 keychain，可填路径并在需要时配套密码解锁
CODESIGN_KEYCHAIN=
CODESIGN_KEYCHAIN_PASSWORD=
CODESIGN_KEYCHAIN_PASSWORD_FILE=
UPLOAD_TEMP_DIR=./tmp/uploads
MAX_VIDEO_SIZE=2147483648
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_TIMEOUT_SECONDS=10
AV_SCRAPER_BASE_URL=https://javdb.com
AV_SCRAPER_TIMEOUT_SECONDS=120
AV_SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; VideoServerBot/1.0; +https://example.invalid/bot)
TRANSLATION_API_URL=http://127.0.0.1:8000/v1
TRANSLATION_API_KEY=
TRANSLATION_MODEL=HY-MT1.5-1.8B
TRANSLATION_TIMEOUT_SECONDS=15
IMAGE_GENERATION_API_URL=
IMAGE_GENERATION_API_KEY=
IMAGE_GENERATION_MODEL=gpt-image-2
IMAGE_GENERATION_TIMEOUT_SECONDS=180
