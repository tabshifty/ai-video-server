APP_MODE=server
HTTP_ADDR=:8080
ENABLE_SWAGGER=true
POSTGRES_DSN=postgres://video:video@127.0.0.1:5432/video_server?sslmode=disable
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
JWT_SECRET=change_me_to_a_long_random_secret
PLAY_URL_SIGN_SECRET=
ASYNQ_QUEUE=transcode
MAX_TRANSCODE_WORKERS=2
ACCESS_TOKEN_TTL_HOURS=24
REFRESH_TOKEN_TTL_HOURS=168
STORAGE_ROOT=./storage
POSTER_STORAGE_PATH=./storage/posters
UPLOAD_TEMP_DIR=./tmp/uploads
MAX_VIDEO_SIZE=2147483648
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_TIMEOUT_SECONDS=10
AV_SCRAPER_BASE_URL=https://javdb.com
AV_SCRAPER_TIMEOUT_SECONDS=10
